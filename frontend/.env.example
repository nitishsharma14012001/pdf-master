# ══════════════════════════════════════════════════════════════════════════════
# PDF Master Frontend — Analytics Environment Variables
# Copy this file to .env (or .env.local for Vite) and fill in your values.
# NEVER commit .env to version control.
# All vars must be prefixed with VITE_ to be exposed to the browser bundle.
# ══════════════════════════════════════════════════════════════════════════════

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Format: G-XXXXXXXXXX
# Find it in GA4 → Admin → Data Streams → your stream → Measurement ID
# Leave blank to disable GA4 without removing any code.
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Search Console verification ───────────────────────────────────────
# The content value from the meta tag Google gives you during GSC setup.
# Paste only the value attribute, e.g. "abcdef1234567890"
# This is rendered in index.html — handled outside of React.
VITE_GSC_VERIFICATION=

# ── Microsoft Clarity ─────────────────────────────────────────────────────────
# Format: 10-character alphanumeric project ID
# Find it in Clarity → Settings → Overview
# Leave blank to disable Clarity without removing any code.
VITE_CLARITY_PROJECT_ID=

# ── Analytics debug mode ──────────────────────────────────────────────────────
# Set to "true" to log every event to the browser console.
# Never enable in production.
VITE_ANALYTICS_DEBUG=false
