# ══════════════════════════════════════════════════════════════════════════════
# PDF Master — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development            # development | production | test

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED in production — use a long random string (openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
# Hard cap applied at the multer layer — no file larger than this is ever
# written to disk (100 MB default).
MAX_FILE_SIZE=104857600         # 100 MB in bytes

# Per-plan caps enforced after auth resolution
MAX_FILE_SIZE_FREE=26214400     # 25 MB — free tier
MAX_FILE_SIZE_PRO=104857600     # 100 MB — pro/business tier

FILE_TTL_HOURS=1                # auto-delete uploaded files after N hours

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production set to your actual frontend domain(s) — no wildcards.
ALLOWED_ORIGINS=http://localhost:3000,https://pdfmaster.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes (global window)
RATE_LIMIT_MAX=500              # max requests per window (global)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # error | warn | info | http | debug
LOG_DIR=./logs

# ── Delete uploads after download ─────────────────────────────────────────────
# Set to true to remove input + output files immediately after the user
# downloads the processed file.  Reduces storage but prevents re-downloads.
DELETE_AFTER_DOWNLOAD=false

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxx
EMAIL_FROM=noreply@pdfmaster.app
